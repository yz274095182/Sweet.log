  margin-top: 20rpx;
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
}

.type-tag {
  margin-top: 16rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 24rpx;
  background-color: rgba(255, 159, 67, 0.1);
  border-radius: 30rpx;
}

.type-icon {
  font-size: 28rpx;
}

.type-text {
  font-size: 26rpx;
  color: #FF9F43;
}

/* 功能列表 */
.menu-card {
  margin-top: 24rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.menu-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 32rpx;
}

.menu-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
}

.menu-icon {
  font-size: 40rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #333333;
}

.menu-arrow {
  font-size: 40rpx;
  color: #CCCCCC;
  font-weight: 300;
}

.menu-divider {
  height: 1rpx;
  background-color: #F0F0F0;
  margin-left: 92rpx;
}

/* 底部信息 */
.footer-info {
  margin-top: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #CCCCCC;
}

/* Loading */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-card {
  width: 300rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #FF9F43;
  border-top-color: transparent;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #333333;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}
</style>
