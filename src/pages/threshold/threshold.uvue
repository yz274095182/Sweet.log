  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.threshold-inputs {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.threshold-input-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.threshold-input-label {
  font-size: 22rpx;
  color: #999999;
}

.threshold-input {
  width: 100%;
  height: 80rpx;
  background-color: #F8F9FA;
  border-radius: 16rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
}

.threshold-divider {
  font-size: 32rpx;
  color: #CCCCCC;
  margin-top: 20rpx;
}

.threshold-default {
  margin-top: 12rpx;
  text-align: center;
}

.threshold-default-text {
  font-size: 22rpx;
  color: #CCCCCC;
}

/* 保存按钮 */
.save-btn {
  margin-top: 40rpx;
  width: 100%;
  height: 100rpx;
  background-color: #FF9F43;
  border-radius: 50rpx;
  border: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.save-btn:active {
  background-color: #E8892E;
}

