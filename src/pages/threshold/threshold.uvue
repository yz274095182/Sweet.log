  background-color: #CCCCCC;
}

.save-btn-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #FFFFFF;
}

/* 重置按钮 */
.reset-btn {
  margin-top: 24rpx;
  width: 100%;
  height: 88rpx;
  background-color: transparent;
  border-radius: 44rpx;
  border: 2rpx solid #E0E0E0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.reset-btn-text {
