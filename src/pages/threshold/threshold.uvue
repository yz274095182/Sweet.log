<template>
  <view class="page-container">
    <!-- 提示信息 -->
    <view class="notice-card">
      <text class="notice-icon">⚠️</text>
      <text class="notice-text">系统标准仅供参考，请优先遵从主治医生建议进行调整。</text>
    </view>

    <!-- 阈值设置列表 -->
    <view class="threshold-card">
      <view class="threshold-header">
        <text class="threshold-title">各时段警戒线设置</text>
        <text class="threshold-subtitle">单位：mmol/L</text>
      </view>

      <view class="threshold-list">
        <view v-for="tag in timeTags" :key="tag" class="threshold-item">
          <view class="threshold-item-header">
            <text class="threshold-item-icon">{{ getTagIcon(tag) }}</text>
            <text class="threshold-item-name">{{ tag }}</text>
          </view>
          <view class="threshold-inputs">
            <view class="threshold-input-group">
              <text class="threshold-input-label">最低</text>
              <input
                class="threshold-input"
                type="digit"
                :value="thresholds[tag].min.toString()"
                @input="(e: any) => onMinChange(tag, e.detail.value)"
              />
            </view>
            <text class="threshold-divider">-</text>
            <view class="threshold-input-group">
              <text class="threshold-input-label">最高</text>
              <input
                class="threshold-input"
                type="digit"
                :value="thresholds[tag].max.toString()"
                @input="(e: any) => onMaxChange(tag, e.detail.value)"
              />
            </view>
          </view>
          <view class="threshold-default">
            <text class="threshold-default-text">系统默认：{{ defaultThresholds[tag].min }} - {{ defaultThresholds[tag].max }}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 保存按钮 -->
    <button class="save-btn" @click="saveThresholds" :disabled="isSaving">
      <text v-if="!isSaving" class="save-btn-text">保存设置</text>
      <text v-else class="save-btn-text">保存中...</text>
    </button>

    <!-- 重置按钮 -->
    <button class="reset-btn" @click="resetToDefault">
      <text class="reset-btn-text">恢复系统默认</text>
    </button>
  </view>
</template>

<script setup lang="uts">
import { ref, onMounted } from 'vue'
import { useUserStore } from '@/store/user'
import { TIME_TAGS, TIME_TAG_ICONS, GDM_THRESHOLDS, NORMAL_THRESHOLDS, type TimeTag } from '@/utils/constants'

const userStore = useUserStore()

// 状态
const isSaving = ref(false)
const timeTags = TIME_TAGS
const defaultThresholds = GDM_THRESHOLDS

// 阈值数据
const thresholds = ref<Record<TimeTag, { min: number; max: number }>>({} as any)

// 获取时段图标
function getTagIcon(tag: TimeTag): string {
  return TIME_TAG_ICONS[tag]
}

// 初始化阈值
onMounted(() => {
  const config = userStore.userInfo?.thresholdConfig
  if (config) {
    // 从用户配置读取
    for (const tag of timeTags) {
      thresholds.value[tag] = config[tag] || {
        min: defaultThresholds[tag].min,
        max: defaultThresholds[tag].max
      }
    }
  } else {
    // 使用系统默认
    for (const tag of timeTags) {
      thresholds.value[tag] = {
        min: defaultThresholds[tag].min,
        max: defaultThresholds[tag].max
      }
    }
  }

  // 同步到默认阈值（根据用户类型）
  if (userStore.getDiabetesType() === 'NORMAL') {
    for (const tag of timeTags) {
      thresholds.value[tag] = {
        min: NORMAL_THRESHOLDS[tag].min,
        max: NORMAL_THRESHOLDS[tag].max
      }
    }
  }
})

// 最低值变化
function onMinChange(tag: TimeTag, value: string) {
  const num = parseFloat(value)
  if (!isNaN(num) && num >= 0 && num < thresholds.value[tag].max) {
    thresholds.value[tag].min = num
  }
}

// 最高值变化
function onMaxChange(tag: TimeTag, value: string) {
  const num = parseFloat(value)
  if (!isNaN(num) && num > thresholds.value[tag].min && num <= 30) {
    thresholds.value[tag].max = num
  }
}

// 保存设置
async function saveThresholds() {
  if (isSaving.value) return

  // 验证
  for (const tag of timeTags) {
    if (thresholds.value[tag].min >= thresholds.value[tag].max) {
      uni.showToast({
        title: `${tag}的最低值必须小于最高值`,
        icon: 'none'
      })
      return
    }
  }

  isSaving.value = true

  try {
    // 逐个更新
    for (const tag of timeTags) {
      await userStore.updateThresholdConfig(
        tag,
        thresholds.value[tag].min,
        thresholds.value[tag].max
      )
    }

    uni.showToast({
      title: '保存成功',
      icon: 'success'
    })

    setTimeout(() => {
      uni.navigateBack()
    }, 1500)
  } catch (e: any) {
    uni.showToast({
      title: '保存失败，请重试',
      icon: 'none'
    })
  } finally {
    isSaving.value = false
  }
}

// 恢复默认
function resetToDefault() {
  uni.showModal({
    title: '确认重置',
    content: '确定要恢复系统默认设置吗？',
    success: (res) => {
      if (res.confirm) {
        const defaults = userStore.getDiabetesType() === 'GDM' ? GDM_THRESHOLDS : NORMAL_THRESHOLDS
        for (const tag of timeTags) {
          thresholds.value[tag] = {
            min: defaults[tag].min,
            max: defaults[tag].max
          }
        }
        uni.showToast({
          title: '已恢复默认',
          icon: 'success'
        })
      }
    }
  })
}
</script>

